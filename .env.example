# Copy to `.env` in this directory (gitignored). Used by the Spring Boot server when started
# with working directory = repo root (Gradle `bootRun` is already configured that way).
#
# Precedence: OS environment variables > this file > classpath application.properties
#
# Render: create a Secret File or set these as environment variables in the dashboard.
# Optional: mount a file and set BATTALION_DOTENV_FILE=/path/to/that/file

# --- PostgreSQL (Spring Boot relaxed binding) ---
SPRING_DATASOURCE_URL=
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=

# --- Optional: CORS for browser REST (comma-separated origins, no spaces) ---
# BATTALION_CORS_ALLOWED_ORIGINS=http://localhost:3000,https://your-app.example/

# --- Dotenv loader itself ---
# BATTALION_DOTENV_FILE=/etc/secrets/battalion.env
# BATTALION_DOTENV_DISABLED=true
